# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth ────────────────────────────────────────────────────
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret
SESSION_SECRET=change-me-in-production

# ─── Twitter / X API ─────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# ─── Somnia Network ──────────────────────────────────────────
SOMNIA_CHAIN_ID=50312
SOMNIA_RPC_URL=https://dream-rpc.somnia.network
SOMNIA_EXPLORER_URL=https://shannon-explorer.somnia.network

# ─── Smart Contracts (filled after deploy) ───────────────────
# Paste the addresses printed by contracts/scripts/deploy.js. These MUST be
# real deployed contracts on the chain set by SOMNIA_CHAIN_ID above — if the
# address is wrong or on the wrong chain, on-chain reads/writes silently fail.
# `npm run preflight` verifies both have bytecode via eth_getCode.
ESCROW_CONTRACT_ADDRESS=
REGISTRY_CONTRACT_ADDRESS=

# ─── Backend Wallet (for registerWallet / registerScreenshot calls) ──────────
# 0x-prefixed 64-hex private key. This wallet signs the app's on-chain writes.
# It MUST be the OWNER of the Escrow/Registry contracts (those methods are
# onlyOwner) — use the same wallet you deployed with, or transferOwnership() to
# it. Fund it with STT/SOMI for gas. Keep it secret; never commit it.
BACKEND_WALLET_PRIVATE_KEY=

# ─── App ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
