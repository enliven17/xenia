# ─── Contract deployment (Hardhat) ──────────────────────────────────────────
# Private key of the wallet that DEPLOYS the contracts.
# Hardhat needs the 0x prefix + 64 hex chars. Fund it with Somnia testnet STT
# (or SOMI on mainnet) so it can pay gas for the deploy.
#
# IMPORTANT: the deployer becomes the contract OWNER. The backend
# (BACKEND_WALLET_PRIVATE_KEY in the root/server .env) calls owner-only methods
# like registerWallet() / registerScreenshot(). Easiest setup is to use the
# SAME wallet here and as the backend wallet. If they differ, you must
# transferOwnership() to the backend wallet after deploy, or those calls revert.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Deployed contract addresses — leave blank; the deploy script prints them.
# Copy the printed values into the backend env (root/.env and Railway).
ESCROW_CONTRACT_ADDRESS=
REGISTRY_CONTRACT_ADDRESS=
