{
  "name": "xenia-somnia-contracts",
  "version": "1.0.0",
  "description": "Xenia smart contracts for Somnia Network",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network somnia_testnet",
