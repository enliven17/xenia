# ═══════════════════════════════════════════════════════════════════════════
# XENIA — Environment variables
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to `.env` for local development.
# For deployment, set these in:
#   - Vercel  → Project Settings → Environment Variables  (only VITE_* vars)
#   - Railway → Project → Variables                       (all backend vars)
#
# ═══════════════════════════════════════════════════════════════════════════


# ─── Somnia Network ────────────────────────────────────────────────────────
# Active chain — leave 50312 for testnet, switch to 50313 for mainnet
SOMNIA_CHAIN_ID=50312
SOMNIA_RPC_URL=https://dream-rpc.somnia.network

# Deployed contract addresses (run scripts/deploy.js inside contracts/ first).
# These MUST be real deployed contracts on the chain selected by SOMNIA_CHAIN_ID
# above — `npm run preflight` checks both actually have bytecode on-chain.
ESCROW_CONTRACT_ADDRESS=0xYourEscrowAddress
REGISTRY_CONTRACT_ADDRESS=0xYourRegistryAddress

# Backend wallet — signs on-chain writes (registerWallet / registerScreenshot).
# ⚠️ MUST be the OWNER of the Escrow/Registry contracts (those methods are
# onlyOwner). Easiest: use the SAME wallet you deployed the contracts with.
# If it differs from the deployer, transferOwnership() to it or the calls revert.
# 0x-prefixed 64 hex chars. Keep private. Fund with STT/SOMI for gas.
BACKEND_WALLET_PRIVATE_KEY=0xabc...


# ─── Database (Neon Postgres — serverless-compatible) ──────────────────────
DATABASE_URL=postgresql://user:pass@ep-host.neon.tech/xenia?sslmode=require


# ─── Sessions ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-32-byte-hex-string


# ─── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. MUST include your Vercel URL.
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173


# ─── Privy (Auth + Embedded Wallets) ───────────────────────────────────────
PRIVY_APP_ID=clxxxx
PRIVY_APP_SECRET=privy-app-secret


# ─── Twitter / X API ───────────────────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=


# ─── AI provider (bot tip-command parsing) ─────────────────────────────────
# auto = prefer Gemini, then Claude, then regex-only. Set "gemini" to force it.
AI_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001


# ─── Runtime ───────────────────────────────────────────────────────────────
# Railway sets PORT automatically; leave default for local dev.
PORT=3000
NODE_ENV=development


# ═══════════════════════════════════════════════════════════════════════════
# FRONTEND (Vite) variables — only `VITE_*` keys reach the browser
# Put these in Vercel → Environment Variables
# ═══════════════════════════════════════════════════════════════════════════

# `testnet` (default) or `mainnet` — controls Somnia chain in the React app
VITE_SOMNIA_CHAIN=testnet
